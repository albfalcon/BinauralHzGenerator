private void iniciarAudio(){if (threadAtiva) return;

audioThread = new Thread(() -> {try {AudioFormat formato = new AudioFormat(44100, 16, 2, true, false);linha = AudioSystem.getSourceDataLine(formato);linha.open(formato, 4096);linha.start();

     int bufferSize = 1024;
     byte[] buffer = new byte[bufferSize * 4];
     double sampleRate = 44100.0;
     double fase1 = 0.0;
     double fase2 = 0.0;

     threadAtiva = true;

     while (osc10n || osc20n || ganhoAtual1 > 0.001 || ganhoAtual2 > 0.001 ) {
         
         double velocidadeFade = 0.001;
         
                 
         
         double inc1 = 2.0 * Math.PI * frequencia1 / sampleRate;
         double inc2 = 2.0 * Math.PI * frequencia2 / sampleRate;

         for (int i = 0; i < bufferSize; i++) {
             
             ganhoAtual1 += (ganhoAlvo1 - ganhoAtual1) * velocidadeFade;
             ganhoAtual2 += (ganhoAlvo2 - ganhoAtual2) * velocidadeFade;
         
             double amostraEsquerda = 0.0;
             double amostraDireita = 0.0;

             /*if (ganhoAtual1  > 0.001) {
                 double onda1 = Math.sin(fase1)*ganhoAtual1;
                 amostraEsquerda += onda1;
                 if (!binaural) amostraDireita += onda1;
                 fase1 += inc1;
                 if (fase1 >= 2.0 * Math.PI) fase1 -= 2.0 * Math.PI;
             }

             if (ganhoAtual1 > 0.001){
                 double onda1 = Math.sin(fase1)*ganhoAtual1;
                 
                 //  Ganho separado para cada canal no binaural
                 double ganhoEsq1 = 1.0;
                 double ganhoDir1 = binaural ? 0.0 : 1.0;
                 
                 amostraEsquerda += onda1 * ganhoEsq1;
                 amostraDireita  += onda1 * ganhoDir1;
                 
                 fase1 += inc1;
                 if(fase1 >= 2.0*Math.PI)fase1 -= 2.0*Math.PI;
                
             }
             */
             if(ganhoAtual1 > 0.001){
                 double onda1 = Math.sin(fase1)*ganhoAtual1;
                 
                 //  Fade suave para o canal direito no modo binaural
                 ganhoDirBinaural += (ganhoAlvoDirBinaural - ganhoDirBinaural) * velocidadeFade;
                 
                 amostraEsquerda += onda1;                    //esquerda sempretoca
                 amostraDireita += onda1 *  ganhoDirBinaural;// dir fade in/out
                 
                 fase1 += inc1;
                 if(fase1 >= 2.0 * Math.PI) fase1 -= 2.0 * Math.PI;
             }
             
             
             if (ganhoAtual2 > 0.001) {
                 double onda2 = Math.sin(fase2)*ganhoAtual2;
                 if (binaural) {
                     amostraDireita += onda2;
                 } else {
                     amostraEsquerda += onda2;
                     amostraDireita += onda2;
                 }
                 fase2 += inc2;
                 if (fase2 >= 2.0 * Math.PI) fase2 -= 2.0 * Math.PI;
             }

             double amplitude = 0.4*Short.MAX_VALUE;

             short sEsq = (short) (amplitude * amostraEsquerda);
             short sDir = (short) (amplitude * amostraDireita);

             int idx = i * 4;
             buffer[idx]     = (byte) (sEsq & 0xFF);
             buffer[idx + 1] = (byte) ((sEsq >> 8) & 0xFF);
             buffer[idx + 2] = (byte) (sDir & 0xFF);
             buffer[idx + 3] = (byte) ((sDir >> 8) & 0xFF);
         }
         linha.write(buffer, 0, buffer.length);
     }

     linha.drain();
     linha.stop();
     linha.close();

 } catch (LineUnavailableException e) {
     SwingUtilities.invokeLater(() -> {
         JOptionPane.showMessageDialog(this, 
             "Erro ao abrir dispositivo de áudio", "ERRO", 
             JOptionPane.ERROR_MESSAGE);
     });
 } finally {
     threadAtiva = false;
     audioThread = null;
 }

});

audioThread.setDaemon(true);audioThread.start();}

